//@version=5
// HISTORICAL (superseded by 08b_trend_rsi_state.pine — kept for reference).
// Verdict: not profitable in the <1 year window tested — an invalid sample
// size anyway. Donchian breakout remains a candidate for an ensemble with
// 8b (see "open questions" in the README).
strategy("10 Donchian Breakout Long Only (Daily)", overlay=true, initial_capital=10000,
     default_qty_type=strategy.percent_of_equity, default_qty_value=100,
     commission_type=strategy.commission.percent, commission_value=0.1)

entryLen = input.int(20, "Entry channel length")
exitLen = input.int(10, "Exit channel length")
emaLen = input.int(200, "Trend filter EMA")

upperChannel = ta.highest(high, entryLen)[1]
lowerChannel = ta.lowest(low, exitLen)[1]
emaValue = ta.ema(close, emaLen)

if close > upperChannel and close > emaValue and strategy.position_size == 0
    strategy.entry("Long", strategy.long)
if close < lowerChannel and strategy.position_size > 0
    strategy.close("Long")

plot(upperChannel, "Entry channel", color=color.green)
plot(lowerChannel, "Exit channel", color=color.red)
plot(emaValue, "EMA 200", color=color.orange)
