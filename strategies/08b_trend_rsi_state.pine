//@version=5
// ============================================================================
// STRATEGY 8b — Trend + RSI state rule  (THE FINAL, VALIDATED STRATEGY)
//
// Rule: be LONG while close > EMA(200) AND RSI(14) > 55; flat otherwise.
// BTC, DAILY timeframe, long-only, spot, no leverage.
//
// Validated in Python (Binance BTCUSDT daily 2017-2026, 100% of capital):
//   strategy +3659% | Sharpe 1.28 | MaxDD -57%
//   hold     +1301% | Sharpe 0.79 | MaxDD -83%
// Confirmed on TradingView (spot, 2018-2026): +2068% vs hold +603%.
//
// Honest caveat: it beats hold only ~4 of 10 years. The entire edge comes
// from losing little in crashes (2018: -36% vs -73%; 2022: -8% vs -64%).
// Realistic forward expectation (walk-forward): Sharpe ~0.5-0.7 with about
// half the drawdown of holding.
//
// Alerts: enable "BUY signal" / "SELL signal" (or order-fill alerts) to get
// notified on state changes.
// ============================================================================
strategy("08b Trend + RSI State (Daily, Long Only)",
     overlay=true,
     initial_capital=10000,
     default_qty_type=strategy.percent_of_equity,
     default_qty_value=100,
     commission_type=strategy.commission.percent,
     commission_value=0.1,
     slippage=5,
     calc_on_every_tick=false)

emaLen = input.int(200, "EMA length", minval=10)
rsiLen = input.int(14, "RSI length", minval=2)
rsiThreshold = input.float(55, "RSI threshold", minval=0, maxval=100)

emaValue = ta.ema(close, emaLen)
rsiValue = ta.rsi(close, rsiLen)

// State rule: this is the key difference vs the original strategy 8.
// Not a crossover event — a condition we want to be in whenever it holds.
inState = close > emaValue and rsiValue > rsiThreshold

if inState and strategy.position_size == 0
    strategy.entry("Long", strategy.long, alert_message="BUY: 8b state ON (close > EMA200 and RSI > 55)")
if not inState and strategy.position_size > 0
    strategy.close("Long", alert_message="SELL: 8b state OFF (trend or momentum broken)")

plot(emaValue, "EMA 200", color=color.orange, linewidth=2)
bgcolor(inState ? color.new(color.green, 92) : na)

buySignal = inState and not inState[1]
sellSignal = not inState and inState[1]
alertcondition(buySignal, "BUY signal", "8b BUY: close > EMA200 and RSI > 55 — go long")
alertcondition(sellSignal, "SELL signal", "8b SELL: state broken — exit to cash")
