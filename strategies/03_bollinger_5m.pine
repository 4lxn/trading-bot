//@version=5
// HISTORICAL (superseded by 08b_trend_rsi_state.pine — kept for reference).
// Verdict: not profitable on BTC 5m. Band touches are noise at this
// timeframe; costs dominate.
strategy("03 Bollinger Bands (5m)", overlay=true, initial_capital=10000,
     default_qty_type=strategy.percent_of_equity, default_qty_value=100,
     commission_type=strategy.commission.percent, commission_value=0.1)

length = input.int(20, "Length")
mult = input.float(2.0, "StdDev multiplier")

basis = ta.sma(close, length)
dev = mult * ta.stdev(close, length)
upper = basis + dev
lower = basis - dev

if ta.crossover(close, lower)
    strategy.entry("Long", strategy.long)
if ta.crossunder(close, upper) or ta.crossunder(close, basis)
    strategy.close("Long")

plot(basis, "Basis", color=color.orange)
plot(upper, "Upper", color=color.gray)
plot(lower, "Lower", color=color.gray)
