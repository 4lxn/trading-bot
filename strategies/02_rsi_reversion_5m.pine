//@version=5
// HISTORICAL (superseded by 08b_trend_rsi_state.pine — kept for reference).
// Verdict: not profitable on BTC 5m. Mean reversion fights the trend and
// the fees finish the job.
strategy("02 RSI Mean Reversion (5m)", overlay=true, initial_capital=10000,
     default_qty_type=strategy.percent_of_equity, default_qty_value=100,
     commission_type=strategy.commission.percent, commission_value=0.1)

rsiLen = input.int(14, "RSI length")
oversold = input.float(30, "Oversold level")
overbought = input.float(70, "Overbought level")

rsiValue = ta.rsi(close, rsiLen)

if ta.crossover(rsiValue, oversold)
    strategy.entry("Long", strategy.long)
if ta.crossunder(rsiValue, overbought)
    strategy.close("Long")
