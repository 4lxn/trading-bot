# Copy this file to `.env` and fill in your values.
# `.env` is gitignored — NEVER commit real keys.

# --- Execution mode ---------------------------------------------------------
# dry-run  : no exchange keys needed; paper position tracked in state/paper_state.json
# testnet  : Binance Spot testnet (fake money) — https://testnet.binance.vision
# live     : real money. Only after weeks of dry-run + testnet.
MODE=dry-run

# --- Binance API keys -------------------------------------------------------
# Create keys WITHOUT withdrawal permission. Trading + reading balances only.
# For testnet, create keys at https://testnet.binance.vision
BINANCE_API_KEY=
BINANCE_API_SECRET=

# --- Strategy parameters (validated by walk-forward optimization) -----------
# SYMBOLS: comma-separated; each runs the 8b rule independently on an equal
#          share of the capital. BTC+ETH+SOL is the validated portfolio
#          (SWEEP_RESULTS.md). SYMBOL=... (singular) still works as fallback.
SYMBOLS=BTC/USDT,ETH/USDT,SOL/USDT
EMA_LEN=200
RSI_LEN=14
RSI_THRESHOLD=55

# --- Position sizing --------------------------------------------------------
# ORDER_FRAC: fraction of the available USDT bucket to deploy on a buy.
#             1.0 matches the backtest. In dry-run each symbol has its own
#             bucket (PAPER_USDT split equally), so 1.0 = equal weight.
# MAX_USDT:   hard cap on the USDT amount of any single buy order. On
#             testnet/live with several symbols this is what enforces equal
#             weight: set it to (capital / number of symbols).
# PAPER_USDT: starting paper capital for dry-run (split across SYMBOLS).
ORDER_FRAC=1.0
MAX_USDT=333
PAPER_USDT=1000

# --- Telegram notifications -------------------------------------------------
# Create a bot with @BotFather, get your chat id with @userinfobot.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
