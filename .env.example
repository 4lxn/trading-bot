# Copy this file to `.env` and fill in your values.
# `.env` is gitignored — NEVER commit real keys.

# --- Execution mode ---------------------------------------------------------
# dry-run  : no exchange keys needed; paper position tracked in state/paper_state.json
# testnet  : Binance Spot testnet (fake money) — https://testnet.binance.vision
# live     : real money. Only after weeks of dry-run + testnet.
MODE=dry-run

# --- Binance API keys -------------------------------------------------------
# Create keys WITHOUT withdrawal permission. Trading + reading balances only.
# For testnet, create keys at https://testnet.binance.vision
BINANCE_API_KEY=
BINANCE_API_SECRET=

# --- Strategy parameters (validated by walk-forward optimization) -----------
SYMBOL=BTC/USDT
EMA_LEN=200
RSI_LEN=14
RSI_THRESHOLD=55

# --- Position sizing --------------------------------------------------------
# ORDER_FRAC: fraction of available USDT to deploy when the signal turns long.
#             1.0 matches the backtest (100% of capital). Lower it to be
#             more conservative.
# MAX_USDT:   hard cap on the USDT amount of any single buy order.
ORDER_FRAC=1.0
MAX_USDT=1000

# --- Telegram notifications -------------------------------------------------
# Create a bot with @BotFather, get your chat id with @userinfobot.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
